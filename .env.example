# Public Supabase browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Server-only Supabase key; never expose this in NEXT_PUBLIC variables
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# OneMap credentials. The server exchanges these for a 72-hour token.
ONEMAP_API_EMAIL=you@example.com
ONEMAP_API_PASSWORD=YOUR_ONEMAP_PASSWORD

